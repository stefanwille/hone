{
  "name": "ai-coding-agent",
  "description": "A terminal-based AI coding agent built from scratch with the Anthropic Claude API, Bun, and TypeScript",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bun run src/main.ts",
    "format": "oxfmt --write \"**/*.{ts,tsx,js,jsx}\"",
    "lint": "oxlint",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "typecheck": "tsc --noEmit",
    "verify": "bun format && bun lint && bun typecheck && bun test"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.52.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@anthropic-ai/sandbox-runtime": "^0.0.42",
    "@anthropic-ai/sdk": "^0.78.0",
    "arktype": "^2.2.0"
  }
}
